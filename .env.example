# ================================================
# CONFIGURAÇÕES DO SERVIDOR
# ================================================

# Porta onde o servidor Express irá rodar
PORT=3000

# ================================================
# SUPABASE — Banco de dados
# ================================================

# URL do seu projeto Supabase
# Encontrada em: Supabase Dashboard > Project Settings > API > Project URL
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (anon key) do Supabase
# Encontrada em: Supabase Dashboard > Project Settings > API > Project API Keys
# ⚠️  Use somente a "anon / public key". NUNCA use a "service_role key" aqui.
SUPABASE_KEY=sua_anon_key_aqui